<h2>Signup</h2>

<form method="POST" action="#">
  <div class="mb-3">
    <label>Name</label>
    <input type="text" class="form-control">
  </div>
  <div class="mb-3">
    <label>Email</label>
    <input type="email" class="form-control">
  </div>
  <div class="mb-3">
    <label>Password</label>
    <input type="password" class="form-control">
  </div>
  <button class="btn btn-success">Signup</button>
</form>
